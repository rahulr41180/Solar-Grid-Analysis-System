# Optional: point the frontend at the Express + MySQL backend.
# Leave unset to run fully frontend-only (scenes persist to localStorage).
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Scene read source: 'local' (default) or 'db'.
# Saves always go to BOTH localStorage and the DB (when the API is configured).
# Reads come from localStorage until you set this to 'db'.
# NEXT_PUBLIC_SCENE_SOURCE=local
